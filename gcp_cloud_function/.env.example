# ============================================================
# 環境變數範本 (複製此檔案為 .env 並填入真實值)
# GCP Cloud Run 請在控制台直接設定以下變數
# ============================================================

# Newtalk API
NEWTALK_API_BASE=https://stage.newtalk.tw/aiArticle
NEWTALK_API_TOKEN=

# Anthropic Claude API
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Google Gemini API
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

# AI 供應商 (anthropic 或 gemini)
AI_PROVIDER=gemini

# GCP 專案 ID (若 Cloud Run 自動偵測失敗時使用)
# GCP_PROJECT_ID=your-project-id
